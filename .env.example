# Публичный URL сайта (для canonical, sitemap, Open Graph). Без слэша в конце.
VITE_SITE_URL=https://wwm-wiki-nocthra.ru

# --- Синхронизация парсеров (админка → /api/sync-content) ---
# ЭТО НЕ КЛЮЧ SUPABASE. Придумайте свою случайную строку, например:
#   node -e "console.log('wwm-sync-'+require('crypto').randomBytes(24).toString('hex'))"
# Локально — в .env. На Vercel — Settings → Environment Variables → SYNC_API_SECRET → Redeploy.
SYNC_API_SECRET=wwm-sync-замените-на-свой-секрет

# --- LM Studio (локальный ИИ для парсеров, только при npm run dev) ---
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
# Токен из LM Studio → Developer → Server Settings → Manage Tokens (если включена аутентификация)
# LM_STUDIO_API_KEY=sk-lm-ваш-токен
LM_STUDIO_MODEL=mistralai/ministral-3-3b
# AI_ENRICH_LIMIT=40
# AI_BATCH_SIZE=2
# AI_TIMEOUT_MS=180000

# --- Vercel (обязательно для деплоя) ---
# Dashboard → ваш проект → Settings → Environment Variables
# Добавьте VITE_SUPABASE_* и SYNC_API_SECRET для Production и Preview.
# После сохранения: Deployments → ⋯ → Redeploy.

# --- Миграция на self-hosted Supabase (только локально, не коммитить) ---
