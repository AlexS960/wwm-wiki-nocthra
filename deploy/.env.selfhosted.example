# Self-hosted WWM Wiki — переменные окружения
# Скопируйте: cp deploy/.env.selfhosted.example deploy/.env.selfhosted
# НЕ коммитьте deploy/.env.selfhosted с реальными секретами!

# =============================================================================
# Домены (REG.RU)
# =============================================================================
SITE_DOMAIN=wwm-wiki-nocthra.ru
API_DOMAIN=api.wwm-wiki-nocthra.ru
# Публичный URL Supabase API (тот же что VITE_SUPABASE_URL при сборке фронта)
SUPABASE_PUBLIC_URL=https://api.wwm-wiki-nocthra.ru

# =============================================================================
# PostgreSQL (контейнер db в Supabase Docker)
# =============================================================================
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong-postgres-password

# Для scripts/apply-migrations.sh и migrate-from-supabase.mjs --import
DATABASE_URL=postgresql://postgres:change-me-strong-postgres-password@localhost:5432/postgres

# =============================================================================
# JWT / ключи Supabase (сгенерируйте ОДИН раз, одинаковые в compose и .env.production)
# Официальный способ: в клоне supabase/docker → ./utils/generate-keys.sh
# Или: https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
# =============================================================================
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# =============================================================================
# Сборка фронтенда (.env.production на Windows перед npm run build)
# =============================================================================
VITE_SUPABASE_URL=https://api.wwm-wiki-nocthra.ru
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_SITE_URL=https://wwm-wiki-nocthra.ru

# =============================================================================
# Sync API (парсеры в админке, server/index.mjs)
# =============================================================================
SYNC_API_SECRET=wwm-sync-change-me
SYNC_API_PORT=3001
SYNC_API_HOST=127.0.0.1

# Опционально: AI-обогащение парсеров (как на Vercel)
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# =============================================================================
# Supabase Docker (официальный стек — deploy/setup-supabase-docker.sh)
# =============================================================================
# После клонирования supabase/docker скопируйте эти значения в deploy/supabase-upstream/docker/.env
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me-dashboard
SECRET_KEY_BASE=change-me-secret-key-base-min-64-chars-recommended-for-production-use-only
VAULT_ENC_KEY=change-me-32-char-vault-key!!

# CORS: разрешить фронтенд
ADDITIONAL_REDIRECT_URLS=
SITE_URL=https://wwm-wiki-nocthra.ru

# =============================================================================
# Деплой статики (deploy/deploy-firstvds.sh)
# =============================================================================
SERVER_HOST=62.109.19.21
SERVER_USER=deploy
SERVER_PORT=22
REMOTE_PATH=/var/www/wwm-wiki
# SSH_KEY_PATH=C:/Users/You/.ssh/id_ed25519

# =============================================================================
# Экспорт из облачного Supabase (только на время миграции, локально на Windows)
# =============================================================================
# SUPABASE_URL=https://xxxx.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=eyJ...  # Dashboard → API → service_role — СЕКРЕТ
