# Шаблон переменных для production-сборки (Vite).
# Скопируйте в корень проекта как .env.production (не коммитьте!) или экспортируйте в CI.
# ВАЖНО: переменные VITE_* вшиваются в JS при npm run build — задайте их ДО сборки.

# --- Обязательно ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Публичный URL сайта (без слэша в конце). Используется для canonical, sitemap, Open Graph.
# Пример после подключения домена на REG.RU:
VITE_SITE_URL=https://wwm-wiki.example.ru

# Альтернативное имя (для скриптов generate-seo.mjs вне Vite):
# SITE_URL=https://wwm-wiki.example.ru

# --- Только для Vercel / serverless API синхронизации парсеров ---
# На FirstVDS статический фронтенд — /api/sync-content недоступен без отдельного бэкенда.
# SYNC_API_SECRET=wwm-sync-your-secret
