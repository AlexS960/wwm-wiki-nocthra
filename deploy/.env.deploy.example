# Переменные для скриптов deploy/deploy-firstvds.ps1 и deploy-firstvds.sh
# Скопируйте в deploy/.env.deploy (не коммитьте!)

# IP или hostname VPS FirstVDS
SERVER_HOST=62.109.19.21

# SSH-пользователь (обычно root или отдельный deploy)
SERVER_USER=deploy

# Путь к каталогу сайта на сервере
REMOTE_PATH=/var/www/wwm-wiki

# Порт SSH (по умолчанию 22)
# SERVER_PORT=22

# Путь к приватному ключу (опционально)
# SSH_KEY_PATH=C:\Users\You\.ssh\id_ed25519
