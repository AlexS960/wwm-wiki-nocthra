{
  "name": "react-vite-tailwind",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-seo.mjs && vite build",
    "seo:generate": "node scripts/generate-seo.mjs",
    "preview": "vite preview",
    "vercel:deploy": "npm run build && vercel deploy --prod -y",
